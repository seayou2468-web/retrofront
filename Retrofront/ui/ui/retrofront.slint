import { Button, TabWidget, ScrollView } from "std-widgets.slint";

export struct UiRow {
    title: string,
    subtitle: string,
}

component FrostPanel inherits Rectangle {
    in property <length> panel-radius: 28px;
    in property <brush> panel-bg: #121a2b;
    border-radius: panel-radius;
    background: panel-bg;
    border-width: 1px;
    border-color: #ffffff14;
    drop-shadow-color: #00000066;
    drop-shadow-blur: 24px;
    drop-shadow-offset-y: 8px;
}

component ClickRow inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> badge;
    callback clicked;
    height: 76px;
    border-radius: 22px;
    background: ta.pressed ? #3478f6 : (ta.has-hover ? #24314c : #172033);
    border-width: 1px;
    border-color: ta.has-hover ? #5b8dff88 : #ffffff12;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 14px;
        spacing: 14px;
        Rectangle {
            width: 42px;
            height: 42px;
            border-radius: 15px;
            background: @linear-gradient(135deg, #5f8cff 0%, #62e3ff 100%);
            Text { text: root.badge; color: white; font-size: 15px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
        }
        VerticalLayout {
            alignment: center;
            spacing: 4px;
            Text { text: root.title; color: #f7fbff; font-size: 17px; font-weight: 800; overflow: elide; }
            Text { text: root.subtitle; color: #aab7cf; font-size: 12px; overflow: elide; }
        }
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

component StudioAction inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <string> icon;
    callback clicked;
    height: 96px;
    border-radius: 28px;
    background: area.pressed ? #2f67ff : (area.has-hover ? #1d2a45 : #111a2c);
    border-width: 1px;
    border-color: area.has-hover ? #83d8ff99 : #ffffff16;
    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 16px;
        Rectangle {
            width: 52px;
            height: 52px;
            border-radius: 22px;
            background: @linear-gradient(145deg, #6ea8ff 0%, #9b7cff 48%, #61f0d5 100%);
            Text { text: root.icon; color: white; font-size: 22px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
        }
        VerticalLayout {
            alignment: center;
            spacing: 5px;
            Text { text: root.title; color: white; font-size: 18px; font-weight: 900; overflow: elide; }
            Text { text: root.detail; color: #aab7cf; font-size: 12px; overflow: elide; }
        }
    }
    area := TouchArea { clicked => { root.clicked(); } }
}

component MetricCard inherits FrostPanel {
    in property <string> title;
    in property <string> value;
    in property <string> accent;
    width: 190px;
    height: 112px;
    panel-radius: 26px;
    panel-bg: #151f34;
    VerticalLayout {
        padding: 18px;
        spacing: 8px;
        Text { text: root.accent; color: #7ed7ff; font-size: 13px; font-weight: 800; }
        Text { text: root.title; color: #d8e4f8; font-size: 13px; }
        Text { text: root.value; color: white; font-size: 22px; font-weight: 900; overflow: elide; }
    }
}

component SectionTitle inherits Text {
    in property <string> label;
    text: label;
    color: #f7fbff;
    font-size: 25px;
    font-weight: 900;
}

component Pill inherits Rectangle {
    in property <string> label;
    height: 34px;
    min-width: 112px;
    border-radius: 17px;
    background: #ffffff12;
    border-width: 1px;
    border-color: #ffffff22;
    Text { text: root.label; color: #e8f2ff; font-size: 12px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
}

component EmptyState inherits FrostPanel {
    in property <string> title;
    in property <string> detail;
    in property <string> icon;
    height: 122px;
    panel-radius: 26px;
    panel-bg: #0d1524;
    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 16px;
        Rectangle {
            width: 58px;
            height: 58px;
            border-radius: 22px;
            background: @linear-gradient(145deg, #22345b 0%, #1d6b81 100%);
            Text { text: root.icon; color: white; font-size: 25px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
        }
        VerticalLayout {
            alignment: center;
            spacing: 7px;
            Text { text: root.title; color: white; font-size: 18px; font-weight: 900; overflow: elide; }
            Text { text: root.detail; color: #aab7cf; font-size: 13px; wrap: word-wrap; }
        }
    }
}

component ParityCard inherits FrostPanel {
    in property <string> title;
    in property <string> body;
    in property <string> badge;
    height: 130px;
    panel-radius: 30px;
    panel-bg: @linear-gradient(135deg, #13213a 0%, #102f4b 100%);
    VerticalLayout {
        padding: 18px;
        spacing: 9px;
        HorizontalLayout {
            spacing: 10px;
            Pill { label: root.badge; }
            Text { text: root.title; color: white; font-size: 18px; font-weight: 900; overflow: elide; }
        }
        Text { text: root.body; color: #aab7cf; font-size: 13px; wrap: word-wrap; }
    }
}

export component MainWindow inherits Window {
    title: "Retrofront Studio";
    preferred-width: 1440px;
    preferred-height: 920px;
    background: @linear-gradient(155deg, #08111f 0%, #11192a 40%, #162d47 100%);

    in property <string> status_text;
    in property <string> state_text;
    in property <string> current_core_text;
    in property <string> current_game_text;
    in property <image> video_frame;
    in property <[UiRow]> cores;
    in property <[UiRow]> games;
    in property <[UiRow]> settings;
    in property <[UiRow]> menu_entries;
    in property <[UiRow]> runtime_stats;
    in property <[UiRow]> api_rows;
    in property <[UiRow]> directory_rows;
    in property <[UiRow]> feature_rows;
    in property <string> menu_title;
    in property <string> cores_count_text;
    in property <string> games_count_text;
    in property <string> settings_count_text;
    in property <string> api_count_text;
    in property <string> storage_count_text;
    in property <string> feature_count_text;
    in property <string> runtime_count_text;
    in property <string> shell_mode_text;
    in property <string> library_hint_text;
    in property <string> core_hint_text;

    callback refresh_requested;
    callback scan_games_requested;
    callback load_core_requested(int);
    callback launch_game_requested(int);
    callback frame_requested;
    callback play_pause_requested;
    callback stop_requested;
    callback reset_requested;
    callback save_state_requested;
    callback load_state_requested;
    callback save_sram_requested;
    callback menu_back_requested;
    callback show_home_requested;
    callback show_core_menu_requested;
    callback show_content_menu_requested;
    callback show_settings_menu_requested;
    callback show_quick_menu_requested;
    callback activate_menu_entry_requested(int);

    VerticalLayout {
        padding: 22px;
        spacing: 18px;

        FrostPanel {
            height: 130px;
            panel-radius: 34px;
            panel-bg: @linear-gradient(110deg, #173057 0%, #245fcf 55%, #75dfff 100%);
            HorizontalLayout {
                padding-left: 26px;
                padding-right: 22px;
                spacing: 18px;
                VerticalLayout {
                    alignment: center;
                    spacing: 5px;
                    Text { text: "Retrofront Studio"; color: white; font-size: 38px; font-weight: 900; }
                    Text { text: "Native iOS + Linux libretro frontend • 100% Slint / Rust UI shell"; color: #eaf7ff; font-size: 14px; font-weight: 700; }
                }
                Rectangle { width: 1px; background: #ffffff55; }
                VerticalLayout {
                    alignment: center;
                    spacing: 7px;
                    HorizontalLayout { spacing: 8px; Pill { label: root.state_text; } Pill { label: root.shell_mode_text; } Pill { label: "SwiftUI parity"; } }
                    Text { text: root.status_text; color: white; font-size: 16px; font-weight: 800; overflow: elide; }
                    Text { text: root.current_core_text + "  •  " + root.current_game_text; color: #d7ecff; font-size: 12px; overflow: elide; }
                }
                Button { text: "Refresh"; clicked => { root.refresh_requested(); } }
                Button { text: "Scan ROMs"; clicked => { root.scan_games_requested(); } }
                Button { text: "Play / Pause"; clicked => { root.play_pause_requested(); } }
            }
        }

        HorizontalLayout {
            spacing: 18px;
            MetricCard { accent: "STATE"; title: "Active runtime"; value: root.state_text; }
            MetricCard { accent: "CORES"; title: "Discovered cores"; value: root.cores_count_text; }
            MetricCard { accent: "GAMES"; title: "Scanned library"; value: root.games_count_text; }
            MetricCard { accent: "SETTINGS"; title: "Config rows"; value: root.settings_count_text; }
            MetricCard { accent: "API"; title: "Runtime surface"; value: root.api_count_text; }
        }

        TabWidget {
            Tab {
                title: "Dashboard";
                HorizontalLayout {
                    spacing: 16px;
                    FrostPanel {
                        width: 390px;
                        panel-bg: #111a2c;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionTitle { label: "Runtime telemetry"; }
                            Text { text: root.runtime_count_text + " live rows • " + root.storage_count_text + " storage paths • " + root.feature_count_text + " parity checks"; color: #9fb0ca; font-size: 13px; }
                            ScrollView { VerticalLayout { spacing: 9px; for row[index] in root.runtime_stats: ClickRow { title: row.title; subtitle: row.subtitle; badge: "R"; } } }
                        }
                    }
                    FrostPanel {
                        panel-bg: #05070c;
                        Image { source: root.video_frame; image-fit: contain; width: parent.width; height: parent.height; }
                        Rectangle { x: 18px; y: 18px; width: parent.width - 36px; height: 58px; border-radius: 18px; background: #00000080; }
                        Text { x: 36px; y: 30px; text: root.current_game_text; color: white; font-size: 18px; font-weight: 900; overflow: elide; }
                    }
                    FrostPanel {
                        width: 320px;
                        panel-bg: #111a2c;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionTitle { label: "Command deck"; }
                            StudioAction { icon: "▶"; title: "Run one frame"; detail: "Step retro_run and refresh telemetry"; clicked => { root.frame_requested(); } }
                            StudioAction { icon: "↻"; title: "Reset runtime"; detail: "Call retro_reset on the active core"; clicked => { root.reset_requested(); } }
                            StudioAction { icon: "◈"; title: "Save state"; detail: "Serialize state slot 0"; clicked => { root.save_state_requested(); } }
                            StudioAction { icon: "◆"; title: "Load state"; detail: "Unserialize state slot 0"; clicked => { root.load_state_requested(); } }
                            StudioAction { icon: "S"; title: "Flush SRAM"; detail: "Persist RETRO_MEMORY_SAVE_RAM"; clicked => { root.save_sram_requested(); } }
                            Button { text: "Stop Content"; clicked => { root.stop_requested(); } }
                        }
                    }
                }
            }
            Tab {
                title: "Library";
                HorizontalLayout {
                    spacing: 16px;
                    FrostPanel {
                        panel-bg: #111a2c;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionTitle { label: "Library"; }
                            Text { text: root.games_count_text + " games • " + root.library_hint_text; color: #9fb0ca; font-size: 13px; }
                            EmptyState { title: "Drop ROMs in Files"; detail: root.library_hint_text; icon: "G"; visible: root.games_count_text == "0"; }
                            ScrollView { VerticalLayout { spacing: 9px; for game[index] in root.games: ClickRow { title: game.title; subtitle: game.subtitle; badge: "G"; clicked => { root.launch_game_requested(index); } } } }
                        }
                    }
                    FrostPanel {
                        width: 430px;
                        panel-bg: #111a2c;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionTitle { label: "Cores"; }
                            Text { text: root.cores_count_text + " cores • " + root.core_hint_text; color: #9fb0ca; font-size: 13px; }
                            EmptyState { title: "No cores discovered"; detail: root.core_hint_text; icon: "C"; visible: root.cores_count_text == "0"; }
                            ScrollView { VerticalLayout { spacing: 9px; for core[index] in root.cores: ClickRow { title: core.title; subtitle: core.subtitle; badge: "C"; clicked => { root.load_core_requested(index); } } } }
                        }
                    }
                }
            }
            Tab {
                title: "libretro API";
                FrostPanel {
                    panel-bg: #111a2c;
                    VerticalLayout {
                        padding: 20px;
                        spacing: 13px;
                        SectionTitle { label: "libretro connection matrix"; }
                        Text { text: "The Rust core now presents a broad frontend surface: lifecycle, environment negotiation, VFS v4, AV, input, options, memory, menus, storage, sensors and platform service hooks. Unsupported host capabilities are explicitly acknowledged with safe stubs instead of silent gaps."; color: #aab7cf; font-size: 14px; }
                        ScrollView { VerticalLayout { spacing: 9px; for api[index] in root.api_rows: ClickRow { title: api.title; subtitle: api.subtitle; badge: "A"; } } }
                    }
                }
            }
            Tab {
                title: "Pro Controls";
                HorizontalLayout {
                    spacing: 16px;
                    FrostPanel {
                        width: 420px;
                        panel-bg: @linear-gradient(155deg, #111a2c 0%, #132642 100%);
                        VerticalLayout {
                            padding: 20px;
                            spacing: 14px;
                            SectionTitle { label: "Session operations"; }
                            StudioAction { icon: "⟳"; title: "Refresh frontend state"; detail: "Rescan UI rows and runtime metrics"; clicked => { root.refresh_requested(); } }
                            StudioAction { icon: "◎"; title: "Scan ROM library"; detail: "Discover compatible content using core info extensions"; clicked => { root.scan_games_requested(); } }
                            StudioAction { icon: "Ⅱ"; title: "Play / pause shell"; detail: "Toggle the Slint transport loop"; clicked => { root.play_pause_requested(); } }
                            StudioAction { icon: "■"; title: "Stop + SRAM flush"; detail: "Unload content and persist save RAM"; clicked => { root.stop_requested(); } }
                            Text { text: "Visual density, core telemetry, launch planning, Files-compatible storage, and runtime controls are implemented in Slint/Rust."; color: #9fb0ca; font-size: 13px; }
                        }
                    }
                    FrostPanel {
                        width: 420px;
                        panel-bg: #111a2c;
                        VerticalLayout { padding: 20px; spacing: 12px; SectionTitle { label: "Storage map"; } ScrollView { VerticalLayout { spacing: 9px; for dir[index] in root.directory_rows: ClickRow { title: dir.title; subtitle: dir.subtitle; badge: "D"; } } } }
                    }
                    FrostPanel {
                        panel-bg: #111a2c;
                        VerticalLayout { padding: 20px; spacing: 12px; SectionTitle { label: "Runtime API radar"; } ScrollView { VerticalLayout { spacing: 9px; for api[index] in root.api_rows: ClickRow { title: api.title; subtitle: api.subtitle; badge: "✓"; } } } }
                    }
                }
            }
            Tab {
                title: "Feature Matrix";
                FrostPanel {
                    panel-bg: @linear-gradient(135deg, #111a2c 0%, #1c304f 100%);
                    VerticalLayout {
                        padding: 20px;
                        spacing: 13px;
                        SectionTitle { label: "RetroArch replacement readiness"; }
                        Text { text: "Concrete runtime capabilities are surfaced as first-class Slint UI rows. This covers every former SwiftUI dashboard section plus additional Rust-only menu, video-frame, telemetry and launch-control surfaces."; color: #aab7cf; font-size: 14px; }
                        ScrollView { VerticalLayout { spacing: 9px; for feature[index] in root.feature_rows: ClickRow { title: feature.title; subtitle: feature.subtitle; badge: "F"; } } }
                    }
                }
            }
            Tab {
                title: "Menu";
                HorizontalLayout {
                    spacing: 16px;
                    FrostPanel {
                        width: 285px;
                        panel-bg: #111a2c;
                        VerticalLayout { padding: 18px; spacing: 10px; SectionTitle { label: "Navigation"; } Button { text: "Home"; clicked => { root.show_home_requested(); } } Button { text: "Cores"; clicked => { root.show_core_menu_requested(); } } Button { text: "Library"; clicked => { root.show_content_menu_requested(); } } Button { text: "Settings"; clicked => { root.show_settings_menu_requested(); } } Button { text: "Quick Menu"; clicked => { root.show_quick_menu_requested(); } } Button { text: "Back"; clicked => { root.menu_back_requested(); } } }
                    }
                    FrostPanel {
                        panel-bg: #111a2c;
                        VerticalLayout { padding: 18px; spacing: 12px; SectionTitle { label: root.menu_title; } ScrollView { VerticalLayout { spacing: 9px; for entry[index] in root.menu_entries: ClickRow { title: entry.title; subtitle: entry.subtitle; badge: "M"; clicked => { root.activate_menu_entry_requested(index); } } } } }
                    }
                }
            }
            Tab {
                title: "SwiftUI Parity";
                HorizontalLayout {
                    spacing: 16px;
                    FrostPanel {
                        width: 470px;
                        panel-bg: #111a2c;
                        VerticalLayout {
                            padding: 20px;
                            spacing: 13px;
                            SectionTitle { label: "Former SwiftUI sections"; }
                            ParityCard { badge: "✓"; title: "Hero + status"; body: "Slint owns launch, status, current core/game and native iOS/Linux shell mode."; }
                            ParityCard { badge: "✓"; title: "Metrics"; body: "State, cores, games, settings and API counts are live properties from Rust."; }
                            ParityCard { badge: "✓"; title: "Command deck"; body: "Run frame, reset, save/load state, SRAM flush, stop and transport loop are wired."; }
                        }
                    }
                    FrostPanel {
                        panel-bg: #111a2c;
                        VerticalLayout {
                            padding: 20px;
                            spacing: 13px;
                            SectionTitle { label: "Added beyond SwiftUI"; }
                            ParityCard { badge: "+"; title: "Clickable RetroArch menu"; body: "Menu entries activate Rust menu actions, core lists, content lists, quick menu branches and settings branches."; }
                            ParityCard { badge: "+"; title: "Live video viewport"; body: "Last software frame is converted to a Slint image and refreshed during frame stepping or playback."; }
                            ParityCard { badge: "+"; title: "Desktop + iOS one shell"; body: "Linux and iOS both use the same Slint file, Rust callbacks and storage/layout model."; }
                        }
                    }
                }
            }
            Tab {
                title: "Settings";
                FrostPanel {
                    panel-bg: #111a2c;
                    VerticalLayout { padding: 18px; spacing: 12px; SectionTitle { label: "RetroArch-compatible storage and options"; } ScrollView { VerticalLayout { spacing: 9px; for setting[index] in root.settings: ClickRow { title: setting.title; subtitle: setting.subtitle; badge: "S"; } } } }
                }
            }
        }
    }
}
