import { Button, TabWidget, ScrollView } from "std-widgets.slint";

export struct UiRow {
    title: string,
    subtitle: string,
}

component FrostPanel inherits Rectangle {
    in property <length> panel-radius: 28px;
    in property <brush> panel-bg: #121a2b;
    border-radius: panel-radius;
    background: panel-bg;
    border-width: 1px;
    border-color: #ffffff14;
    drop-shadow-color: #00000066;
    drop-shadow-blur: 24px;
    drop-shadow-offset-y: 8px;
}

component ClickRow inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> badge;
    callback clicked;
    height: 76px;
    border-radius: 22px;
    background: ta.pressed ? #3478f6 : (ta.has-hover ? #24314c : #172033);
    border-width: 1px;
    border-color: ta.has-hover ? #5b8dff88 : #ffffff12;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 14px;
        spacing: 14px;
        Rectangle {
            width: 42px;
            height: 42px;
            border-radius: 15px;
            background: @linear-gradient(135deg, #5f8cff 0%, #62e3ff 100%);
            Text { text: root.badge; color: white; font-size: 15px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
        }
        VerticalLayout {
            alignment: center;
            spacing: 4px;
            Text { text: root.title; color: #f7fbff; font-size: 17px; font-weight: 800; overflow: elide; }
            Text { text: root.subtitle; color: #aab7cf; font-size: 12px; overflow: elide; }
        }
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

component MetricCard inherits FrostPanel {
    in property <string> title;
    in property <string> value;
    in property <string> accent;
    width: 190px;
    height: 112px;
    panel-radius: 26px;
    panel-bg: #151f34;
    VerticalLayout {
        padding: 18px;
        spacing: 8px;
        Text { text: root.accent; color: #7ed7ff; font-size: 13px; font-weight: 800; }
        Text { text: root.title; color: #d8e4f8; font-size: 13px; }
        Text { text: root.value; color: white; font-size: 22px; font-weight: 900; overflow: elide; }
    }
}

component SectionTitle inherits Text {
    in property <string> label;
    text: label;
    color: #f7fbff;
    font-size: 25px;
    font-weight: 900;
}

component Pill inherits Rectangle {
    in property <string> label;
    height: 34px;
    min-width: 112px;
    border-radius: 17px;
    background: #ffffff12;
    border-width: 1px;
    border-color: #ffffff22;
    Text { text: root.label; color: #e8f2ff; font-size: 12px; font-weight: 800; horizontal-alignment: center; vertical-alignment: center; }
}

export component MainWindow inherits Window {
    title: "Retrofront Studio";
    preferred-width: 1280px;
    preferred-height: 820px;
    background: @linear-gradient(155deg, #08111f 0%, #11192a 40%, #162d47 100%);

    in property <string> status_text;
    in property <string> state_text;
    in property <string> current_core_text;
    in property <string> current_game_text;
    in property <image> video_frame;
    in property <[UiRow]> cores;
    in property <[UiRow]> games;
    in property <[UiRow]> settings;
    in property <[UiRow]> menu_entries;
    in property <[UiRow]> runtime_stats;
    in property <[UiRow]> api_rows;
    in property <string> menu_title;

    callback refresh_requested;
    callback scan_games_requested;
    callback load_core_requested(int);
    callback launch_game_requested(int);
    callback frame_requested;
    callback play_pause_requested;
    callback stop_requested;
    callback reset_requested;
    callback save_state_requested;
    callback load_state_requested;
    callback save_sram_requested;
    callback menu_back_requested;
    callback show_home_requested;
    callback show_core_menu_requested;
    callback show_content_menu_requested;
    callback show_settings_menu_requested;
    callback show_quick_menu_requested;

    VerticalLayout {
        padding: 22px;
        spacing: 18px;

        FrostPanel {
            height: 130px;
            panel-radius: 34px;
            panel-bg: @linear-gradient(110deg, #173057 0%, #245fcf 55%, #75dfff 100%);
            HorizontalLayout {
                padding-left: 26px;
                padding-right: 22px;
                spacing: 18px;
                VerticalLayout {
                    alignment: center;
                    spacing: 5px;
                    Text { text: "Retrofront Studio"; color: white; font-size: 38px; font-weight: 900; }
                    Text { text: "Desktop-class libretro control center • Slint / Rust"; color: #eaf7ff; font-size: 14px; font-weight: 700; }
                }
                Rectangle { width: 1px; background: #ffffff55; }
                VerticalLayout {
                    alignment: center;
                    spacing: 7px;
                    HorizontalLayout { spacing: 8px; Pill { label: root.state_text; } Pill { label: "One UI inspired"; } }
                    Text { text: root.status_text; color: white; font-size: 16px; font-weight: 800; overflow: elide; }
                    Text { text: root.current_core_text + "  •  " + root.current_game_text; color: #d7ecff; font-size: 12px; overflow: elide; }
                }
                Button { text: "Refresh"; clicked => { root.refresh_requested(); } }
                Button { text: "Scan ROMs"; clicked => { root.scan_games_requested(); } }
                Button { text: "Play / Pause"; clicked => { root.play_pause_requested(); } }
            }
        }

        HorizontalLayout {
            spacing: 18px;
            MetricCard { accent: "CORE"; title: "Active runtime"; value: root.state_text; }
            MetricCard { accent: "CONTENT"; title: "Current game"; value: root.current_game_text; }
            MetricCard { accent: "LIBRETRO"; title: "Connected APIs"; value: "VFS / AV / Input"; }
            MetricCard { accent: "UI"; title: "Shell mode"; value: "Studio"; }
        }

        TabWidget {
            Tab {
                title: "Dashboard";
                HorizontalLayout {
                    spacing: 16px;
                    FrostPanel {
                        width: 390px;
                        panel-bg: #111a2c;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;
                            SectionTitle { label: "Runtime telemetry"; }
                            ScrollView { VerticalLayout { spacing: 9px; for row[index] in root.runtime_stats: ClickRow { title: row.title; subtitle: row.subtitle; badge: "R"; } } }
                        }
                    }
                    FrostPanel {
                        panel-bg: #05070c;
                        Image { source: root.video_frame; image-fit: contain; width: parent.width; height: parent.height; }
                        Rectangle { x: 18px; y: 18px; width: parent.width - 36px; height: 58px; border-radius: 18px; background: #00000080; }
                        Text { x: 36px; y: 30px; text: root.current_game_text; color: white; font-size: 18px; font-weight: 900; overflow: elide; }
                    }
                    FrostPanel {
                        width: 255px;
                        panel-bg: #111a2c;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            SectionTitle { label: "Transport"; }
                            Button { text: "Run Frame"; clicked => { root.frame_requested(); } }
                            Button { text: "Reset"; clicked => { root.reset_requested(); } }
                            Button { text: "Save State"; clicked => { root.save_state_requested(); } }
                            Button { text: "Load State"; clicked => { root.load_state_requested(); } }
                            Button { text: "Save SRAM"; clicked => { root.save_sram_requested(); } }
                            Button { text: "Stop Content"; clicked => { root.stop_requested(); } }
                        }
                    }
                }
            }
            Tab {
                title: "Library";
                HorizontalLayout {
                    spacing: 16px;
                    FrostPanel {
                        panel-bg: #111a2c;
                        VerticalLayout { padding: 18px; spacing: 12px; SectionTitle { label: "Games"; } ScrollView { VerticalLayout { spacing: 9px; for game[index] in root.games: ClickRow { title: game.title; subtitle: game.subtitle; badge: "G"; clicked => { root.launch_game_requested(index); } } } } }
                    }
                    FrostPanel {
                        width: 430px;
                        panel-bg: #111a2c;
                        VerticalLayout { padding: 18px; spacing: 12px; SectionTitle { label: "Cores"; } ScrollView { VerticalLayout { spacing: 9px; for core[index] in root.cores: ClickRow { title: core.title; subtitle: core.subtitle; badge: "C"; clicked => { root.load_core_requested(index); } } } } }
                    }
                }
            }
            Tab {
                title: "libretro API";
                FrostPanel {
                    panel-bg: #111a2c;
                    VerticalLayout {
                        padding: 20px;
                        spacing: 13px;
                        SectionTitle { label: "Connected frontend interfaces"; }
                        Text { text: "Lifecycle, VFS, AV, input, options, save memory, platform services, and graceful stubs are wired from the UI shell into the Rust frontend core."; color: #aab7cf; font-size: 14px; }
                        ScrollView { VerticalLayout { spacing: 9px; for api[index] in root.api_rows: ClickRow { title: api.title; subtitle: api.subtitle; badge: "A"; } } }
                    }
                }
            }
            Tab {
                title: "Menu";
                HorizontalLayout {
                    spacing: 16px;
                    FrostPanel {
                        width: 285px;
                        panel-bg: #111a2c;
                        VerticalLayout { padding: 18px; spacing: 10px; SectionTitle { label: "Navigation"; } Button { text: "Home"; clicked => { root.show_home_requested(); } } Button { text: "Cores"; clicked => { root.show_core_menu_requested(); } } Button { text: "Library"; clicked => { root.show_content_menu_requested(); } } Button { text: "Settings"; clicked => { root.show_settings_menu_requested(); } } Button { text: "Quick Menu"; clicked => { root.show_quick_menu_requested(); } } Button { text: "Back"; clicked => { root.menu_back_requested(); } } }
                    }
                    FrostPanel {
                        panel-bg: #111a2c;
                        VerticalLayout { padding: 18px; spacing: 12px; SectionTitle { label: root.menu_title; } ScrollView { VerticalLayout { spacing: 9px; for entry[index] in root.menu_entries: ClickRow { title: entry.title; subtitle: entry.subtitle; badge: "M"; } } } }
                    }
                }
            }
            Tab {
                title: "Settings";
                FrostPanel {
                    panel-bg: #111a2c;
                    VerticalLayout { padding: 18px; spacing: 12px; SectionTitle { label: "RetroArch-compatible storage and options"; } ScrollView { VerticalLayout { spacing: 9px; for setting[index] in root.settings: ClickRow { title: setting.title; subtitle: setting.subtitle; badge: "S"; } } } }
                }
            }
        }
    }
}
