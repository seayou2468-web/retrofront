import { Button, TabWidget, ScrollView, VerticalBox, HorizontalBox } from "std-widgets.slint";

export struct UiRow {
    title: string,
    subtitle: string,
}

component ClickRow inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    callback clicked;
    height: 68px;
    border-radius: 14px;
    background: ta.pressed ? #2b5fb8 : (ta.has-hover ? #223756 : #172238);
    border-width: 1px;
    border-color: #304569;

    VerticalLayout {
        padding-left: 16px;
        padding-right: 16px;
        padding-top: 10px;
        padding-bottom: 8px;
        spacing: 4px;
        Text { text: root.title; color: #eef4ff; font-size: 16px; font-weight: 700; overflow: elide; }
        Text { text: root.subtitle; color: #9fb4d6; font-size: 12px; overflow: elide; }
    }

    ta := TouchArea { clicked => { root.clicked(); } }
}

component SectionTitle inherits Text {
    in property <string> label;
    text: label;
    color: #f7fbff;
    font-size: 24px;
    font-weight: 800;
}

export component MainWindow inherits Window {
    title: "Retrofront Slint";
    preferred-width: 1100px;
    preferred-height: 760px;
    background: #0c1320;

    in property <string> status_text;
    in property <string> state_text;
    in property <string> current_core_text;
    in property <string> current_game_text;
    in property <image> video_frame;
    in property <[UiRow]> cores;
    in property <[UiRow]> games;
    in property <[UiRow]> settings;
    in property <[UiRow]> menu_entries;
    in property <string> menu_title;

    callback refresh_requested;
    callback scan_games_requested;
    callback load_core_requested(int);
    callback launch_game_requested(int);
    callback frame_requested;
    callback play_pause_requested;
    callback stop_requested;
    callback reset_requested;
    callback save_state_requested;
    callback load_state_requested;
    callback save_sram_requested;
    callback menu_back_requested;
    callback show_home_requested;
    callback show_core_menu_requested;
    callback show_content_menu_requested;
    callback show_settings_menu_requested;
    callback show_quick_menu_requested;

    VerticalLayout {
        padding: 18px;
        spacing: 14px;

        Rectangle {
            height: 96px;
            border-radius: 22px;
            background: @linear-gradient(110deg, #16335d 0%, #1e63d6 54%, #53d8ff 100%);
            HorizontalLayout {
                padding-left: 24px;
                padding-right: 24px;
                spacing: 16px;
                VerticalLayout {
                    alignment: center;
                    Text { text: "Retrofront"; color: white; font-size: 34px; font-weight: 900; }
                    Text { text: "Linux + iOS Slint UI"; color: #e6f6ff; font-size: 14px; }
                }
                Rectangle { width: 1px; background: #ffffff55; }
                VerticalLayout {
                    alignment: center;
                    Text { text: root.state_text; color: white; font-size: 18px; font-weight: 700; }
                    Text { text: root.status_text; color: #eaf6ff; font-size: 13px; overflow: elide; }
                    Text { text: root.current_core_text + " • " + root.current_game_text; color: #d4ecff; font-size: 12px; overflow: elide; }
                }
                Button { text: "Refresh"; clicked => { root.refresh_requested(); } }
                Button { text: "Scan ROMs"; clicked => { root.scan_games_requested(); } }
            }
        }

        TabWidget {
            Tab {
                title: "Library";
                HorizontalLayout {
                    spacing: 14px;
                    Rectangle {
                        border-radius: 18px;
                        background: #10192a;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 10px;
                            SectionTitle { label: "Games"; }
                            ScrollView {
                                VerticalLayout {
                                    spacing: 8px;
                                    for game[index] in root.games: ClickRow {
                                        title: game.title;
                                        subtitle: game.subtitle;
                                        clicked => { root.launch_game_requested(index); }
                                    }
                                }
                            }
                        }
                    }
                    Rectangle {
                        width: 360px;
                        border-radius: 18px;
                        background: #10192a;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 10px;
                            SectionTitle { label: "Cores"; }
                            ScrollView {
                                VerticalLayout {
                                    spacing: 8px;
                                    for core[index] in root.cores: ClickRow {
                                        title: core.title;
                                        subtitle: core.subtitle;
                                        clicked => { root.load_core_requested(index); }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            Tab {
                title: "Play";
                HorizontalLayout {
                    spacing: 14px;
                    Rectangle {
                        border-radius: 18px;
                        background: #05070c;
                        Image {
                            source: root.video_frame;
                            image-fit: contain;
                            width: parent.width;
                            height: parent.height;
                        }
                        Text {
                            text: root.current_game_text;
                            color: #ffffffaa;
                            x: 18px;
                            y: 18px;
                            font-size: 16px;
                            font-weight: 700;
                        }
                    }
                    Rectangle {
                        width: 260px;
                        border-radius: 18px;
                        background: #10192a;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 10px;
                            SectionTitle { label: "Runtime"; }
                            Button { text: "Run Frame"; clicked => { root.frame_requested(); } }
                            Button { text: "Play / Pause"; clicked => { root.play_pause_requested(); } }
                            Button { text: "Reset"; clicked => { root.reset_requested(); } }
                            Button { text: "Save State"; clicked => { root.save_state_requested(); } }
                            Button { text: "Load State"; clicked => { root.load_state_requested(); } }
                            Button { text: "Save SRAM"; clicked => { root.save_sram_requested(); } }
                            Button { text: "Stop Content"; clicked => { root.stop_requested(); } }
                        }
                    }
                }
            }
            Tab {
                title: "Menu";
                HorizontalLayout {
                    spacing: 14px;
                    Rectangle {
                        width: 260px;
                        border-radius: 18px;
                        background: #10192a;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 10px;
                            SectionTitle { label: "Navigation"; }
                            Button { text: "Home"; clicked => { root.show_home_requested(); } }
                            Button { text: "Cores"; clicked => { root.show_core_menu_requested(); } }
                            Button { text: "Library"; clicked => { root.show_content_menu_requested(); } }
                            Button { text: "Settings"; clicked => { root.show_settings_menu_requested(); } }
                            Button { text: "Quick Menu"; clicked => { root.show_quick_menu_requested(); } }
                            Button { text: "Back"; clicked => { root.menu_back_requested(); } }
                        }
                    }
                    Rectangle {
                        border-radius: 18px;
                        background: #10192a;
                        VerticalLayout {
                            padding: 16px;
                            spacing: 10px;
                            SectionTitle { label: root.menu_title; }
                            ScrollView {
                                VerticalLayout {
                                    spacing: 8px;
                                    for entry in root.menu_entries: ClickRow { title: entry.title; subtitle: entry.subtitle; }
                                }
                            }
                        }
                    }
                }
            }
            Tab {
                title: "Settings";
                Rectangle {
                    border-radius: 18px;
                    background: #10192a;
                    VerticalLayout {
                        padding: 16px;
                        spacing: 10px;
                        SectionTitle { label: "RetroArch-compatible storage and options"; }
                        ScrollView {
                            VerticalLayout {
                                spacing: 8px;
                                for setting in root.settings: ClickRow { title: setting.title; subtitle: setting.subtitle; }
                            }
                        }
                    }
                }
            }
        }
    }
}
