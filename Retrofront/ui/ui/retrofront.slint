import { Button, ScrollView } from "std-widgets.slint";

export struct UiRow {
    title: string,
    subtitle: string,
}

component GlassPanel inherits Rectangle {
    in property <length> radius: 22px;
    in property <brush> fill: #0d1522f0;
    border-radius: radius;
    background: fill;
    border-width: 1px;
    border-color: #ffffff18;
    drop-shadow-color: #00000080;
    drop-shadow-blur: 24px;
    drop-shadow-offset-y: 10px;
}

component NeonButton inherits Rectangle {
    in property <string> text;
    in property <string> icon;
    callback clicked;
    height: 54px;
    border-radius: 16px;
    background: touch.pressed ? #2e74ff : @linear-gradient(110deg, #6d3ff2 0%, #15bde3 100%);
    border-width: 1px;
    border-color: #9ccfff66;
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 10px;
        Text { text: root.icon; color: white; font-size: 18px; font-weight: 900; vertical-alignment: center; }
        Text { text: root.text; color: white; font-size: 14px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

component IconButton inherits Rectangle {
    in property <string> icon;
    callback clicked;
    width: 42px;
    height: 42px;
    border-radius: 13px;
    background: touch.pressed ? #6d3ff2 : (touch.has-hover ? #233252 : #111a2b);
    border-width: 1px;
    border-color: #ffffff1f;
    Text { text: root.icon; color: #e8f2ff; font-size: 18px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
    touch := TouchArea { clicked => { root.clicked(); } }
}

component Pill inherits Rectangle {
    in property <string> text;
    height: 28px;
    min-width: 64px;
    border-radius: 8px;
    background: #17233a;
    border-width: 1px;
    border-color: #ffffff1d;
    Text { text: root.text; color: #dce7ff; font-size: 12px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
}

component NavItem inherits Rectangle {
    in property <string> icon;
    in property <string> text;
    in property <bool> selected: false;
    callback clicked;
    height: 50px;
    border-radius: 13px;
    background: root.selected ? #182c61 : (touch.has-hover ? #121d31 : #00000000);
    border-width: root.selected ? 1px : 0px;
    border-color: #5e7dff66;
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 10px;
        spacing: 12px;
        Text { text: root.icon; color: root.selected ? #ffffff : #aebbd2; font-size: 18px; font-weight: 900; vertical-alignment: center; }
        Text { text: root.text; color: root.selected ? #ffffff : #aebbd2; font-size: 14px; font-weight: 800; vertical-alignment: center; }
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

component GameRow inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <int> index;
    callback clicked;
    height: 58px;
    border-radius: 9px;
    background: root.index == 0 ? #253268bf : (touch.has-hover ? #172338 : #00000000);
    border-width: root.index == 0 ? 1px : 0px;
    border-color: #745dff;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 12px;
        Rectangle {
            width: 44px; height: 44px; border-radius: 7px;
            background: @linear-gradient(135deg, #f0882c 0%, #34235a 50%, #27c4d8 100%);
            Text { text: root.index == 0 ? "SF" : root.index == 1 ? "MS" : root.index == 2 ? "Z" : root.index == 3 ? "SA" : "★"; color: white; font-size: 12px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
        }
        VerticalLayout {
            alignment: center;
            spacing: 3px;
            Text { text: root.title; color: white; font-size: 13px; font-weight: 900; overflow: elide; }
            Text { text: root.subtitle; color: #8996ad; font-size: 11px; overflow: elide; }
        }
        Rectangle { width: 72px; background: #00000000; Text { text: root.index == 0 ? "12h 30m" : root.index == 1 ? "6h 15m" : root.index == 2 ? "8h 45m" : "5h 20m"; color: #aebbd2; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; } }
        IconButton { icon: root.index == 0 ? "▶" : "⋯"; clicked => { root.clicked(); } }
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

component CoreRow inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <int> index;
    callback clicked;
    height: 48px;
    border-radius: 12px;
    background: root.index == 0 ? #322872 : (touch.has-hover ? #172338 : #00000000);
    border-width: root.index == 0 ? 1px : 0px;
    border-color: #6e8cff;
    HorizontalLayout {
        padding-left: 12px; padding-right: 10px; spacing: 12px;
        Rectangle { width: 30px; height: 30px; border-radius: 10px; background: @linear-gradient(135deg, #7e66ff 0%, #00d5ff 100%); Text { text: "✥"; color: white; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; } }
        VerticalLayout { alignment: center; spacing: 2px; Text { text: root.title; color: white; font-size: 12px; font-weight: 900; overflow: elide; } Text { text: root.subtitle; color: #8592aa; font-size: 10px; overflow: elide; } }
        Text { text: root.index == 0 ? "●" : "○"; color: root.index == 0 ? #8e74ff : #526078; font-size: 15px; vertical-alignment: center; }
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

component SettingLine inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    height: 32px;
    background: #00000000;
    HorizontalLayout { spacing: 8px; Text { text: root.title; color: #dbe6fa; font-size: 12px; font-weight: 800; } Text { text: root.subtitle; color: #7f8da6; font-size: 11px; overflow: elide; } }
}

component PhonePreview inherits GlassPanel {
    in property <string> title;
    in property <[UiRow]> rows;
    in property <bool> settings: false;
    width: 255px;
    height: 430px;
    radius: 28px;
    fill: #08101df7;
    border-color: #ffffff40;
    VerticalLayout {
        padding: 17px;
        spacing: 12px;
        HorizontalLayout { Text { text: "22:48"; color: white; font-size: 11px; } Rectangle { } Text { text: "▴ ᯤ ▬"; color: white; font-size: 10px; } }
        HorizontalLayout { Text { text: root.title; color: white; font-size: 18px; font-weight: 900; } Rectangle { } Text { text: root.settings ? "+" : "⌕  ⚗"; color: white; font-size: 16px; } }
        ScrollView { VerticalLayout { spacing: 8px; for row[index] in root.rows: CoreRow { title: row.title; subtitle: row.subtitle; index: index; } } }
        HorizontalLayout {
            spacing: 18px;
            Text { text: "▣\nライブラリ"; color: #c7d1e3; font-size: 9px; horizontal-alignment: center; }
            Text { text: "☷\nプレイリスト"; color: #c7d1e3; font-size: 9px; horizontal-alignment: center; }
            Text { text: "✥\nコア"; color: #c7d1e3; font-size: 9px; horizontal-alignment: center; }
            Text { text: "⚙\n設定"; color: #c7d1e3; font-size: 9px; horizontal-alignment: center; }
        }
    }
}

export component MainWindow inherits Window {
    title: "Retrofront";
    preferred-width: 1440px;
    preferred-height: 920px;
    background: @linear-gradient(150deg, #050b14 0%, #071323 52%, #101d36 100%);

    in property <string> status_text;
    in property <string> state_text;
    in property <string> current_core_text;
    in property <string> current_game_text;
    in property <image> video_frame;
    in property <[UiRow]> cores;
    in property <[UiRow]> games;
    in property <[UiRow]> settings;
    in property <[UiRow]> menu_entries;
    in property <[UiRow]> runtime_stats;
    in property <[UiRow]> api_rows;
    in property <[UiRow]> directory_rows;
    in property <[UiRow]> feature_rows;
    in property <string> menu_title;
    in property <string> cores_count_text;
    in property <string> games_count_text;
    in property <string> settings_count_text;
    in property <string> api_count_text;
    in property <string> storage_count_text;
    in property <string> feature_count_text;
    in property <string> runtime_count_text;
    in property <string> shell_mode_text;
    in property <string> library_hint_text;
    in property <string> core_hint_text;

    callback refresh_requested;
    callback scan_games_requested;
    callback load_core_requested(int);
    callback launch_game_requested(int);
    callback frame_requested;
    callback play_pause_requested;
    callback stop_requested;
    callback reset_requested;
    callback save_state_requested;
    callback load_state_requested;
    callback save_sram_requested;
    callback menu_back_requested;
    callback show_home_requested;
    callback show_core_menu_requested;
    callback show_content_menu_requested;
    callback show_settings_menu_requested;
    callback show_quick_menu_requested;
    callback activate_menu_entry_requested(int);

    VerticalLayout {
        padding: 20px;
        spacing: 12px;
        HorizontalLayout {
            spacing: 12px;
            GlassPanel {
                width: 230px;
                fill: #07111ff5;
                VerticalLayout {
                    padding: 24px;
                    spacing: 14px;
                    Rectangle { width: 46px; height: 46px; border-radius: 23px; background: @linear-gradient(145deg, #2bd5ff 0%, #763cff 65%, #07111f 100%); }
                    NavItem { icon: "▣"; text: "ライブラリ"; selected: true; clicked => { root.show_content_menu_requested(); } }
                    NavItem { icon: "☷"; text: "プレイリスト"; clicked => { root.show_home_requested(); } }
                    NavItem { icon: "✥"; text: "コア"; clicked => { root.show_core_menu_requested(); } }
                    NavItem { icon: "⚙"; text: "設定"; clicked => { root.show_settings_menu_requested(); } }
                    NavItem { icon: "⇩"; text: "ダウンロード"; clicked => { root.refresh_requested(); } }
                    NavItem { icon: "◷"; text: "履歴"; clicked => { root.show_quick_menu_requested(); } }
                    Rectangle { }
                    Text { text: "22:48\n2024/05/20"; color: #9eabc0; font-size: 13px; }
                    Rectangle { height: 70px; border-radius: 14px; background: @linear-gradient(160deg, #09111d 0%, #14213a 58%, #562fc7 100%); }
                    Text { text: root.shell_mode_text + "\n" + root.storage_count_text + " RetroArch directories"; color: #aebbd2; font-size: 11px; }
                }
            }

            VerticalLayout {
                spacing: 12px;
                HorizontalLayout {
                    spacing: 12px;
                    GlassPanel {
                        height: 520px;
                        fill: #091422ee;
                        VerticalLayout {
                            padding: 24px;
                            spacing: 14px;
                            HorizontalLayout {
                                VerticalLayout { spacing: 4px; Text { text: "すべてのゲーム"; color: white; font-size: 20px; font-weight: 900; } Text { text: root.games_count_text + " ゲーム • " + root.library_hint_text; color: #8d9bb3; font-size: 12px; } }
                                Rectangle { }
                                GlassPanel { width: 240px; height: 40px; radius: 20px; fill: #121b2b; Text { text: "⌕  検索"; color: #818fa6; font-size: 13px; vertical-alignment: center; horizontal-alignment: center; } }
                                IconButton { icon: "⚗"; clicked => { root.scan_games_requested(); } }
                                IconButton { icon: "▦"; clicked => { root.refresh_requested(); } }
                                IconButton { icon: "☷"; clicked => { root.show_quick_menu_requested(); } }
                            }
                            HorizontalLayout { spacing: 10px; Text { text: "タイトル"; color: #9aa8bc; font-size: 12px; } Rectangle { } Text { text: "コア"; color: #9aa8bc; font-size: 12px; } Text { text: "最後にプレイ"; color: #9aa8bc; font-size: 12px; } Text { text: "プレイ時間"; color: #9aa8bc; font-size: 12px; } }
                            ScrollView { VerticalLayout { spacing: 4px; for game[index] in root.games: GameRow { title: game.title; subtitle: game.subtitle; index: index; clicked => { root.launch_game_requested(index); } } } }
                        }
                    }
                    GlassPanel {
                        width: 335px;
                        height: 520px;
                        fill: #08111df2;
                        VerticalLayout {
                            padding: 20px;
                            spacing: 14px;
                            Rectangle { height: 225px; border-radius: 16px; background: @linear-gradient(135deg, #08111d 0%, #55331a 52%, #d48b34 100%); Text { text: "Street Fighter III\n3rd Strike"; color: white; font-size: 24px; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; } }
                            Text { text: root.current_game_text; color: white; font-size: 22px; font-weight: 900; wrap: word-wrap; }
                            Text { text: root.current_core_text; color: #9ca9bd; font-size: 13px; overflow: elide; }
                            HorizontalLayout { spacing: 8px; Pill { text: root.state_text; } Pill { text: "★ ★ ★ ☆ ☆"; } Pill { text: "12h 30m"; } }
                            NeonButton { icon: "▶"; text: "プレイ"; clicked => { root.play_pause_requested(); } }
                            HorizontalLayout { spacing: 12px; NeonButton { icon: "✥"; text: "コアをロード"; clicked => { root.show_core_menu_requested(); } } NeonButton { icon: "ⓘ"; text: "詳細"; clicked => { root.show_quick_menu_requested(); } } }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 12px;
                    GlassPanel {
                        width: 385px;
                        height: 250px;
                        fill: #08111df2;
                        VerticalLayout { padding: 20px; spacing: 12px; HorizontalLayout { Text { text: "ROMをインポート"; color: white; font-size: 18px; font-weight: 900; } Rectangle {} Text { text: "×"; color: #aebbd2; font-size: 18px; } } GlassPanel { height: 86px; radius: 10px; fill: #0b1423; Text { text: "⇪\nファイルをドラッグ＆ドロップ または選択"; color: #aebbd2; font-size: 13px; horizontal-alignment: center; vertical-alignment: center; } } SettingLine { title: "スキャン設定"; subtitle: root.library_hint_text; } NeonButton { icon: "⇩"; text: "インポートを開始"; clicked => { root.scan_games_requested(); } } }
                    }
                    GlassPanel {
                        width: 340px;
                        height: 250px;
                        fill: #08111df2;
                        VerticalLayout { padding: 20px; spacing: 10px; Text { text: "コアをロード"; color: white; font-size: 18px; font-weight: 900; } ScrollView { VerticalLayout { spacing: 6px; for core[index] in root.cores: CoreRow { title: core.title; subtitle: core.subtitle; index: index; clicked => { root.load_core_requested(index); } } } } NeonButton { icon: "✥"; text: "コアをロード"; clicked => { root.show_core_menu_requested(); } } }
                    }
                    GlassPanel {
                        height: 250px;
                        fill: #08111df2;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 8px;
                            Rectangle {
                                height: 170px;
                                border-radius: 14px;
                                background: @linear-gradient(150deg, #07111d 0%, #17263b 100%);
                                Image { source: root.video_frame; image-fit: contain; }
                                Text { text: "LIVE FRAME"; color: #ffffff88; font-size: 11px; font-weight: 900; x: 14px; y: 12px; }
                            }
                            HorizontalLayout { spacing: 18px; IconButton { icon: "☰"; clicked => { root.show_quick_menu_requested(); } } IconButton { icon: "▣"; clicked => { root.save_state_requested(); } } IconButton { icon: "⇩"; clicked => { root.load_state_requested(); } } IconButton { icon: "⟳"; clicked => { root.reset_requested(); } } IconButton { icon: "⏻"; clicked => { root.stop_requested(); } } Button { text: "SRAM"; clicked => { root.save_sram_requested(); } } }
                        }
                    }
                }
            }
        }

        GlassPanel {
            height: 220px;
            fill: #08111df2;
            HorizontalLayout {
                padding: 18px;
                spacing: 28px;
                VerticalLayout { width: 220px; spacing: 8px; Text { text: "設定"; color: white; font-size: 18px; font-weight: 900; } for setting[index] in root.settings: SettingLine { title: setting.title; subtitle: setting.subtitle; } }
                VerticalLayout { width: 420px; spacing: 10px; Text { text: "RetroArch互換"; color: white; font-size: 18px; font-weight: 900; } ScrollView { VerticalLayout { spacing: 5px; for row[index] in root.feature_rows: SettingLine { title: row.title; subtitle: row.subtitle; } } } }
                PhonePreview { title: "ライブラリ"; rows: root.games; }
                PhonePreview { title: "プレイリスト"; rows: root.menu_entries; }
                PhonePreview { title: "コア"; rows: root.cores; }
                PhonePreview { title: "設定"; rows: root.settings; settings: true; }
            }
        }
    }
}
